#!/usr/bin/env bash
#
# velox-pkgcheck — PKGBUILD security scanner for Velox Linux
# Detects supply-chain attacks before AUR package installation
#
# Covers:
#   - Atomic Arch campaign (June 2026): atomic-lockfile / js-digest eBPF rootkit
#   - CHAOS RAT campaign (July 2025): malicious -bin packages
#   - General PKGBUILD abuse: curl|bash, eval+base64, dropper patterns

VERSION="1.0.0"
PROG="${0##*/}"

# ── Colors (disabled if not a TTY) ────────────────────────────────────────────
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    LRED='\033[1;31m'
    ORANGE='\033[0;33m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    GREEN='\033[0;32m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    RED=''; LRED=''; ORANGE=''; YELLOW=''; BLUE=''
    GREEN=''; CYAN=''; BOLD=''; DIM=''; NC=''
fi

# ── State ─────────────────────────────────────────────────────────────────────
WORST=0          # 0=clean 1=info 2=medium 3=high 4=critical
TOTAL=0
QUIET=0
JSON_OUT=0
declare -a JSON_FINDINGS=()

# ── Known-bad lists ───────────────────────────────────────────────────────────

# Malicious npm/bun packages — update as new campaigns are discovered
MALICIOUS_NPM=(
    "atomic-lockfile"       # Atomic Arch wave 1 (Jun 2026)
    "lockfile-js"           # Atomic Arch variant
    "js-digest"             # Atomic Arch wave 2 (Jun 2026)
    "node-fetch-native-fix" # Earlier campaign (2025)
    "colors-css-kit"        # Earlier campaign (2025)
    "req-lib"
    "lockfile-dep"
)

# Known attacker AUR accounts from Atomic Arch campaign
BAD_MAINTAINERS=(
    "krisztinavarga"
    "franziskaweber"
    "tobiaswesterburg"
    "ellenmyklebust"
    "custodiatovar"
    "veramagalhaes"
    "wave-2"
)

# ── Helpers ───────────────────────────────────────────────────────────────────

_level_num() {
    case "$1" in
        CRITICAL) echo 4 ;; HIGH)   echo 3 ;;
        MEDIUM)   echo 2 ;; INFO)   echo 1 ;;
        *)        echo 0 ;;
    esac
}

_level_color() {
    case "$1" in
        CRITICAL) printf '%b' "${LRED}"   ;;
        HIGH)     printf '%b' "${ORANGE}" ;;
        MEDIUM)   printf '%b' "${YELLOW}" ;;
        INFO)     printf '%b' "${BLUE}"   ;;
    esac
}

finding() {
    local sev="$1" file="$2" linenum="$3" msg="$4" detail="${5:-}"

    local n; n=$(_level_num "$sev")
    [[ $n -gt $WORST ]] && WORST=$n
    (( TOTAL++ ))

    [[ $QUIET -eq 1 && ( "$sev" == "INFO" || "$sev" == "MEDIUM" ) ]] && return

    local col; col=$(_level_color "$sev")
    printf "${col}${BOLD}[%-8s]${NC} ${BOLD}%s${NC}" "$sev" "$file"
    [[ -n "$linenum" ]] && printf "${DIM}:%s${NC}" "$linenum"
    printf " — %s\n" "$msg"
    [[ -n "$detail" ]] && printf "             ${DIM}↳ %s${NC}\n" "$detail"

    if [[ $JSON_OUT -eq 1 ]]; then
        local escaped_msg; escaped_msg=$(printf '%s' "$msg" | sed 's/"/\\"/g')
        JSON_FINDINGS+=("{\"severity\":\"$sev\",\"file\":\"$file\",\"line\":${linenum:-0},\"message\":\"$escaped_msg\"}")
    fi
}

# ── Core PKGBUILD scanner ─────────────────────────────────────────────────────

scan_file() {
    local file="$1"
    [[ ! -f "$file" ]] && { printf "${RED}Not found:${NC} %s\n\n" "$file" >&2; return 1; }

    printf "${BOLD}Scanning:${NC} %s\n" "$file"
    local before=$TOTAL
    local linenum=0

    while IFS= read -r line || [[ -n "$line" ]]; do
        (( linenum++ ))

        # Strip inline comments for pattern matching (preserve line for display)
        local s="${line%%#*}"

        # ── CRITICAL: known malicious npm/bun packages ─────────────────────
        for pkg in "${MALICIOUS_NPM[@]}"; do
            if printf '%s' "$s" | grep -qE "(npm|bun|yarn|pnpm)[[:space:]]+(i|install|add)[[:space:]].*\\b${pkg}\\b|[\"']${pkg}[\"']"; then
                finding "CRITICAL" "$file" "$linenum" \
                    "Known malicious package: ${BOLD}${pkg}${NC}" \
                    "$line"
            fi
        done

        # ── CRITICAL: known attacker account names ─────────────────────────
        for acct in "${BAD_MAINTAINERS[@]}"; do
            if printf '%s' "$line" | grep -qiF "$acct"; then
                finding "CRITICAL" "$file" "$linenum" \
                    "Known Atomic Arch attacker account referenced: ${BOLD}${acct}${NC}" \
                    "$line"
            fi
        done

        # ── HIGH: npm/bun/yarn install called as a command ─────────────────
        # (legitimate nodejs PKGBUILDs use npm run/build, not install from a URL)
        if printf '%s' "$s" | grep -qE '^[[:space:]]*(npm|bun|yarn|pnpm)[[:space:]]+(i|install|add)[[:space:]]'; then
            local already=0
            for pkg in "${MALICIOUS_NPM[@]}"; do
                printf '%s' "$s" | grep -qF "$pkg" && already=1 && break
            done
            [[ $already -eq 0 ]] && finding "HIGH" "$file" "$linenum" \
                "npm/bun/yarn install inside build script — fetches live external packages" \
                "$line"
        fi

        # ── HIGH: download piped directly into a shell ─────────────────────
        # Require at least one argument after curl/wget (real attacks have a URL)
        if printf '%s' "$s" | grep -qE '(curl|wget)[[:space:]]+[^|]+\|[[:space:]]*(bash|sh|zsh|fish|python3?|perl|ruby|node)\b'; then
            finding "HIGH" "$file" "$linenum" \
                "Remote code execution: download piped to shell interpreter" \
                "$line"
        fi

        # ── HIGH: eval with command substitution ──────────────────────────
        if printf '%s' "$s" | grep -qE 'eval[[:space:]]+"?\$\('; then
            finding "HIGH" "$file" "$linenum" \
                "eval with command substitution — common obfuscation technique" \
                "$line"
        fi

        # ── HIGH: base64 decoded payload executed ──────────────────────────
        if printf '%s' "$s" | grep -qE 'base64[[:space:]]+(--decode|-d)[[:space:]]*\|.*(bash|sh|exec|eval|python3?|perl)'; then
            finding "HIGH" "$file" "$linenum" \
                "base64-decoded payload executed — strong obfuscation indicator" \
                "$line"
        fi

        # ── HIGH: download to temp dir ────────────────────────────────────
        if printf '%s' "$s" | grep -qE '^[[:space:]]*(curl|wget)[[:space:]].*(/tmp/|/var/tmp/|/dev/shm/)'; then
            finding "HIGH" "$file" "$linenum" \
                "Downloading to temp directory — potential dropper staging" \
                "$line"
        fi

        # ── HIGH: making temp file executable then running it ─────────────
        if printf '%s' "$s" | grep -qE 'chmod[[:space:]]+\+x[[:space:]]+(/tmp/|/var/tmp/|/dev/shm/)'; then
            finding "HIGH" "$file" "$linenum" \
                "Marking temp file executable — dropper execution pattern" \
                "$line"
        fi

        # ── HIGH: Python/Perl one-liner with exec/eval ────────────────────
        if printf '%s' "$s" | grep -qE "(python3?|python)[[:space:]]+-c[[:space:]]+['\"].*(__import__|exec|eval|compile)"; then
            finding "HIGH" "$file" "$linenum" \
                "Python -c with exec/eval/import — possible obfuscated payload" \
                "$line"
        fi
        if printf '%s' "$s" | grep -qE "perl[[:space:]]+-e[[:space:]]+['\"].*system[[:space:]]*\("; then
            finding "HIGH" "$file" "$linenum" \
                "Perl -e with system() — possible obfuscated payload" \
                "$line"
        fi

        # ── MEDIUM: pip/gem/cargo install ────────────────────────────────
        if printf '%s' "$s" | grep -qE '^[[:space:]]*(pip3?|gem|cargo)[[:space:]]+(install|i)[[:space:]]'; then
            finding "MEDIUM" "$file" "$linenum" \
                "Package manager install in build script — fetches live external dependencies" \
                "$line"
        fi

        # ── MEDIUM: curl/wget as a command outside source=() ─────────────
        # (source=() lines contain URLs as strings, not commands)
        if printf '%s' "$s" | grep -qE '^[[:space:]]*(curl|wget)[[:space:]]'; then
            finding "MEDIUM" "$file" "$linenum" \
                "Network download inside build function — not declared in source=()" \
                "$line"
        fi

        # ── MEDIUM: non-HTTPS source URLs ────────────────────────────────
        if printf '%s' "$s" | grep -qE '"http://[^"]+"|'"'http://[^']+'" ; then
            finding "MEDIUM" "$file" "$linenum" \
                "Non-HTTPS source URL — vulnerable to MITM/injection" \
                "$line"
        fi

        # ── MEDIUM: eBPF or raw kernel module ops ────────────────────────
        if printf '%s' "$s" | grep -qE '(bpftool[[:space:]]|/sys/fs/bpf|insmod[[:space:]].*\.ko[[:space:]]|modprobe[[:space:]])'; then
            finding "MEDIUM" "$file" "$linenum" \
                "eBPF or kernel module operation — verify this is expected" \
                "$line"
        fi

        # ── MEDIUM: long hex-encoded string (obfuscation) ────────────────
        if printf '%s' "$s" | grep -qE '(\\x[0-9a-fA-F]{2}){8,}'; then
            finding "MEDIUM" "$file" "$linenum" \
                "Long hex-encoded string — possible obfuscated payload" \
                "$line"
        fi

        # ── MEDIUM: pacman -U installs a local package ───────────────────
        if printf '%s' "$s" | grep -qE 'pacman[[:space:]]+.*-U[[:space:]]'; then
            finding "MEDIUM" "$file" "$linenum" \
                "pacman -U installs a local package during build — verify its source" \
                "$line"
        fi

        # ── INFO: npm/bun build/run steps (may be legitimate) ────────────
        if printf '%s' "$s" | grep -qE '^[[:space:]]*(npm|bun|yarn|pnpm)[[:space:]]+(run|build|start|test)[[:space:]]'; then
            finding "INFO" "$file" "$linenum" \
                "npm/bun build step — normal for JS packages, confirm package is legitimate" \
                "$line"
        fi

    done < "$file"

    # Recurse into any .install file declared in this PKGBUILD
    if [[ "${file##*/}" == "PKGBUILD" ]]; then
        local install_file dir
        dir="${file%/*}"
        install_file=$(grep -oP "^install\s*=\s*[\"']?\K[^\"' \t\n]+" "$file" 2>/dev/null | head -1)
        if [[ -n "$install_file" && -f "$dir/$install_file" ]]; then
            printf "  ${DIM}→ also scanning %s${NC}\n" "$install_file"
            scan_file "$dir/$install_file"
            return
        fi
    fi

    local new=$(( TOTAL - before ))
    [[ $new -eq 0 ]] && printf "  ${GREEN}✓ No suspicious patterns found${NC}\n"
    printf "\n"
}

scan_directory() {
    local dir="$1"
    printf "${BOLD}${CYAN}Scanning directory:${NC} %s\n\n" "$dir"
    local found=0

    while IFS= read -r -d '' f; do
        scan_file "$f"
        found=1
    done < <(find "$dir" -name "PKGBUILD" -print0 2>/dev/null)

    # Catch standalone .install files not attached to a PKGBUILD
    while IFS= read -r -d '' f; do
        scan_file "$f"
    done < <(find "$dir" -name "*.install" -print0 2>/dev/null)

    [[ $found -eq 0 ]] && printf "${YELLOW}No PKGBUILD files found in %s${NC}\n\n" "$dir"
}

scan_aur_cache() {
    printf "${BOLD}${CYAN}Scanning AUR package caches...${NC}\n\n"
    local found=0

    for cache_dir in \
        "${XDG_CACHE_HOME:-$HOME/.cache}/paru/clone" \
        "${XDG_CACHE_HOME:-$HOME/.cache}/yay"
    do
        [[ ! -d "$cache_dir" ]] && continue
        printf "${DIM}Cache: %s${NC}\n\n" "$cache_dir"
        while IFS= read -r -d '' f; do
            scan_file "$f"
            found=1
        done < <(find "$cache_dir" -name "PKGBUILD" -print0 2>/dev/null)
    done

    [[ $found -eq 0 ]] && printf "${YELLOW}No AUR caches found — paru/yay not used or cache is empty${NC}\n\n"
}

scan_installed() {
    printf "${BOLD}${CYAN}Checking installed AUR packages against attack window...${NC}\n\n"

    local aur_pkgs
    aur_pkgs=$(pacman -Qm 2>/dev/null | awk '{print $1}') || true

    if [[ -z "$aur_pkgs" ]]; then
        printf "${GREEN}No foreign (AUR) packages installed.${NC}\n\n"
        return
    fi

    local count; count=$(wc -l <<< "$aur_pkgs")
    printf "Found %d AUR package(s). Checking pacman.log...\n" "$count"

    if [[ ! -f /var/log/pacman.log ]]; then
        printf "${YELLOW}pacman.log not found — skipping log check${NC}\n\n"
        return
    fi

    # Extract lines from the Atomic Arch attack window
    local window_lines
    window_lines=$(grep -E '^\[2026-06-0[9]|^\[2026-06-1[012]' /var/log/pacman.log 2>/dev/null || true)

    local hits=0
    while IFS= read -r pkg; do
        if printf '%s' "$window_lines" | grep -qF "[ALPM] installed $pkg ("; then
            finding "HIGH" "pacman.log" "" \
                "Package ${BOLD}${pkg}${NC} was installed during Atomic Arch attack window (Jun 9–12 2026)" \
                "Verify at: https://aur.archlinux.org/packages/${pkg}"
            (( hits++ ))
        fi
    done <<< "$aur_pkgs"

    if [[ $hits -eq 0 ]]; then
        printf "  ${GREEN}✓ No AUR packages installed during attack window${NC}\n"
    fi
    printf "\n"
}

check_system() {
    printf "${BOLD}${CYAN}Checking for post-infection indicators...${NC}\n\n"

    # ── eBPF rootkit artifacts ────────────────────────────────────────────
    printf "eBPF rootkit artifacts (/sys/fs/bpf/hidden_*)...\n"
    if compgen -G "/sys/fs/bpf/hidden_*" > /dev/null 2>&1; then
        finding "CRITICAL" "/sys/fs/bpf" "" \
            "eBPF rootkit artifacts found — system may be actively compromised" \
            "Isolate this machine immediately and investigate"
    else
        printf "  ${GREEN}✓ Clean${NC}\n"
    fi
    printf "\n"

    # ── npm cache ─────────────────────────────────────────────────────────
    printf "npm cache for malicious packages...\n"
    local npm_cache="${XDG_DATA_HOME:-$HOME/.local/share}/npm"
    [[ -d "$HOME/.npm" ]] && npm_cache="$HOME/.npm"
    local npm_hit=0
    for pkg in "${MALICIOUS_NPM[@]}"; do
        if [[ -d "$npm_cache/$pkg" ]] || \
           find "$npm_cache" -maxdepth 4 -name "package.json" \
               -exec grep -lqF "\"$pkg\"" {} \; 2>/dev/null; then
            finding "CRITICAL" "npm-cache" "" \
                "Malicious package ${BOLD}${pkg}${NC} present in npm cache" \
                "Run: npm cache clean --force"
            (( npm_hit++ ))
        fi
    done
    [[ $npm_hit -eq 0 ]] && printf "  ${GREEN}✓ Clean${NC}\n"
    printf "\n"

    # ── bun cache ─────────────────────────────────────────────────────────
    printf "bun cache for malicious packages...\n"
    local bun_cache="$HOME/.bun/install/cache"
    local bun_hit=0
    if [[ -d "$bun_cache" ]]; then
        for pkg in "${MALICIOUS_NPM[@]}"; do
            if find "$bun_cache" -maxdepth 5 -name "*.json" \
                   -exec grep -lqF "\"$pkg\"" {} \; 2>/dev/null; then
                finding "CRITICAL" "bun-cache" "" \
                    "Malicious package ${BOLD}${pkg}${NC} present in bun cache" \
                    "Run: rm -rf ~/.bun/install/cache"
                (( bun_hit++ ))
            fi
        done
    fi
    [[ $bun_hit -eq 0 ]] && printf "  ${GREEN}✓ Clean${NC}\n"
    printf "\n"

    # ── Suspicious systemd services ───────────────────────────────────────
    printf "Systemd services for suspicious commands...\n"
    local svc_hit=0
    while IFS= read -r svcfile; do
        if grep -qE '(curl|wget|nc |ncat|netcat|python3? -c|perl -e)' "$svcfile" 2>/dev/null; then
            finding "HIGH" "$svcfile" "" \
                "Service unit contains suspicious network/exec command" \
                "$(grep -Em1 '(curl|wget|nc |ncat|netcat|python3? -c|perl -e)' "$svcfile")"
            (( svc_hit++ ))
        fi
    done < <(find /etc/systemd/system /usr/lib/systemd/system \
                  "${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user" \
                  -name "*.service" 2>/dev/null)
    [[ $svc_hit -eq 0 ]] && printf "  ${GREEN}✓ Clean${NC}\n"
    printf "\n"

    # ── Known exfil staging paths ─────────────────────────────────────────
    printf "Known credential-theft staging paths...\n"
    local stg_hit=0
    for path in /tmp/.s /tmp/.d /var/tmp/.cache /dev/shm/.store /tmp/.out; do
        if [[ -e "$path" ]]; then
            finding "CRITICAL" "$path" "" \
                "Suspicious file/directory at known exfil staging path" \
                "Possible active credential theft"
            (( stg_hit++ ))
        fi
    done
    [[ $stg_hit -eq 0 ]] && printf "  ${GREEN}✓ Clean${NC}\n"
    printf "\n"
}

# ── Summary ───────────────────────────────────────────────────────────────────

print_summary() {
    local line="════════════════════════════════════════════════"
    printf "${BOLD}%s${NC}\n" "$line"
    printf "${BOLD}Total findings:${NC} %d\n" "$TOTAL"
    case $WORST in
        0) printf "${GREEN}${BOLD}  CLEAN${NC}    — no suspicious patterns detected\n" ;;
        1) printf "${BLUE}${BOLD}  INFO${NC}     — informational; manual review recommended\n" ;;
        2) printf "${YELLOW}${BOLD}  MEDIUM${NC}   — suspicious patterns found; review before installing\n" ;;
        3) printf "${ORANGE}${BOLD}  HIGH${NC}     — highly suspicious; do NOT install without careful review\n" ;;
        4) printf "${LRED}${BOLD}  CRITICAL${NC} — known malicious content; do NOT install\n" ;;
    esac
    printf "${BOLD}%s${NC}\n" "$line"

    if [[ $JSON_OUT -eq 1 ]]; then
        local joined
        IFS=',' joined="${JSON_FINDINGS[*]}"
        printf '{"total":%d,"worst":%d,"findings":[%s]}\n' "$TOTAL" "$WORST" "$joined"
    fi
}

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
${BOLD}velox-pkgcheck ${VERSION}${NC} — PKGBUILD supply-chain attack scanner

${BOLD}USAGE${NC}
  ${PROG} [OPTIONS] <PKGBUILD|directory>   Scan a file or directory
  ${PROG} --scan-aur-cache                 Scan all PKGBUILDs in paru/yay cache
  ${PROG} --scan-installed                 Check AUR packages against attack window
  ${PROG} --check-system                   Check for post-infection artifacts

${BOLD}OPTIONS${NC}
  -q, --quiet          Only show HIGH and CRITICAL findings
  -j, --json           Append JSON report to output
  -h, --help           Show this help
      --version        Show version

${BOLD}SEVERITY${NC}
  ${LRED}CRITICAL${NC}  Known malicious package/account (Atomic Arch, prior campaigns)
  ${ORANGE}HIGH${NC}      curl|bash, eval+base64, npm install, temp-dir dropper pattern
  ${YELLOW}MEDIUM${NC}    Non-HTTPS sources, pip/gem install, eBPF ops, pacman -U
  ${BLUE}INFO${NC}      npm build steps — likely fine, worth noting

${BOLD}EXIT CODES${NC}
  0  Clean   1  Info   2  Medium   3  High   4  Critical

${BOLD}EXAMPLES${NC}
  ${PROG} ~/paru/clone/some-pkg/PKGBUILD
  ${PROG} --scan-aur-cache
  ${PROG} --check-system
  ${PROG} -q --scan-installed
EOF
}

# ── Entry point ───────────────────────────────────────────────────────────────

main() {
    [[ $# -eq 0 ]] && { usage; exit 0; }

    local mode="" targets=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)          usage; exit 0 ;;
            --version)          printf "%s %s\n" "$PROG" "$VERSION"; exit 0 ;;
            -q|--quiet)         QUIET=1 ;;
            -j|--json)          JSON_OUT=1 ;;
            --scan-aur-cache)   mode="cache" ;;
            --scan-installed)   mode="installed" ;;
            --check-system)     mode="system" ;;
            -*)                 printf "${RED}Unknown option: %s${NC}\n\n" "$1" >&2
                                usage >&2; exit 1 ;;
            *)                  targets+=("$1") ;;
        esac
        shift
    done

    printf "${BOLD}${CYAN}velox-pkgcheck ${VERSION}${NC}"
    printf " ${DIM}— PKGBUILD Supply-Chain Scanner${NC}\n\n"

    case "$mode" in
        cache)     scan_aur_cache ;;
        installed) scan_installed ;;
        system)    check_system ;;
        *)
            [[ ${#targets[@]} -eq 0 ]] && { usage; exit 0; }
            for t in "${targets[@]}"; do
                if   [[ -d "$t" ]]; then scan_directory "$t"
                elif [[ -f "$t" ]]; then scan_file "$t"
                else printf "${RED}Not found:${NC} %s\n\n" "$t" >&2
                fi
            done
            ;;
    esac

    print_summary
    exit $WORST
}

main "$@"

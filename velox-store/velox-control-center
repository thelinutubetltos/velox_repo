    def _show_snapshots(self):
        self._stack.setCurrentIndex(5)

        # Clear existing rows
        while self._snapshots_layout.count() > 1:
            item = self._snapshots_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()

        try:
            # Check root filesystem is btrfs first
            fs_result = subprocess.run(
                ["findmnt", "-n", "-o", "FSTYPE", "/"],
                capture_output=True, text=True, timeout=5
            )
            root_fs = fs_result.stdout.strip()
            if root_fs != "btrfs":
                raise RuntimeError(
                    f"Root filesystem is {root_fs or 'unknown'}, not BTRFS.\n\n"
                    "Snapper snapshots require the root partition to be formatted as BTRFS.\n\n"
                    "This feature will work on an installed Velox system with BTRFS selected during installation."
                )

            if not shutil.which("snapper"):
                raise RuntimeError(
                    "snapper is not installed.\n\n"
                    "Install it with:  sudo pacman -S snapper"
                )
            result = subprocess.run(
                ["snapper", "list"],
                capture_output=True, text=True, timeout=10
            )
            if result.returncode != 0:
                stderr = result.stderr.strip()
                if "does not exist" in stderr or "not configured" in stderr.lower():
                    self._show_snapper_setup_prompt()
                    return
                raise RuntimeError(stderr or "snapper returned an error.")
            lines = result.stdout.strip().splitlines()
            if len(lines) <= 2:
                raise RuntimeError("No snapshots found")
            for line in lines[2:]:
                parts = [p.strip() for p in line.split("|")]
                if len(parts) < 5:
                    continue
                num, snap_type, user, date, desc = parts[0], parts[1], parts[2], parts[3], parts[4] if len(parts) > 4 else ""
                row_w = QWidget()
                row_w.setMinimumHeight(52)
                row = QHBoxLayout(row_w)
                row.setContentsMargins(0, 8, 0, 8)
                row.setSpacing(16)
                num_lbl = QLabel(f"#{num}")
                num_lbl.setFixedWidth(36)
                num_lbl.setStyleSheet(f"font-size: 13px; font-weight: 700; color: {GREEN};")
                row.addWidget(num_lbl)
                type_lbl = QLabel(snap_type)
                type_lbl.setFixedWidth(70)
                type_lbl.setStyleSheet(f"font-size: 11px; color: {SUBTEXT};")
                row.addWidget(type_lbl)
                date_lbl = QLabel(date)
                date_lbl.setFixedWidth(160)
                date_lbl.setStyleSheet(f"font-size: 12px; color: {TEXT};")
                row.addWidget(date_lbl)
                desc_lbl = QLabel(desc or "—")
                desc_lbl.setStyleSheet(f"font-size: 12px; color: {SUBTEXT};")
                row.addWidget(desc_lbl)
                row.addStretch()
                del_btn = QPushButton("Delete")
                del_btn.setObjectName("danger")
                del_btn.setFixedWidth(80)
                del_btn.clicked.connect(lambda _, n=num: self._snapshot_delete(n))
                row.addWidget(del_btn)
                self._snapshots_layout.insertWidget(
                    self._snapshots_layout.count() - 1, row_w
                )
                sep = QFrame()
                sep.setFrameShape(QFrame.Shape.HLine)
                sep.setStyleSheet("color: #282828;")
                self._snapshots_layout.insertWidget(
                    self._snapshots_layout.count() - 1, sep
                )
        except Exception as e:
            msg = QLabel(f"⚠  {e}")
            msg.setStyleSheet(f"font-size: 14px; color: {SUBTEXT}; padding: 20px;")
            msg.setWordWrap(True)
            self._snapshots_layout.insertWidget(0, msg)


    def _show_results(self, packages: list[Package]):
        # Clear previous content (everything except the trailing stretch)
        while self._results_layout.count() > 1:
            item = self._results_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()
            elif item.layout():
                # clear sub-layout
                while item.layout().count():
                    sub = item.layout().takeAt(0)
                    if sub.widget():
                        sub.widget().deleteLater()

        self._card_map: dict[str, PackageCard] = {}

        capped = packages[:60]
        if not capped:
            self._status_label.setText("No packages found.")
            self._stack.setCurrentIndex(1)
            return

        self._status_label.setText(f"{len(capped)} package(s) found")

        # Group by source preserving order: pacman → aur → flatpak → other
        source_order = ["pacman", "aur", "flatpak"]
        grouped: dict[str, list[Package]] = {}
        for pkg in capped:
            grouped.setdefault(pkg.source, []).append(pkg)

        for source in source_order + [s for s in grouped if s not in source_order]:
            pkgs = grouped.get(source)
            if not pkgs:
                continue

            # Section header
            self._results_layout.insertWidget(
                self._results_layout.count() - 1,
                self._make_source_header(source)
            )

            # Grid container for this source
            grid_widget = QWidget()
            grid = QGridLayout(grid_widget)

    def _run_terminal_cmd(self, title: str, cmd: list):
        self._terminal_title.setText(title)
        self._terminal_output.clear()
        self._terminal_status.setText("Running…")
        self._stack.setCurrentIndex(6)

        self._term_worker = TerminalWorker(cmd)
        self._term_worker.line_ready.connect(
            lambda line: self._terminal_output.append(line)
        )
        self._term_worker.finished_ok.connect(self._on_terminal_done)
        self._term_worker.start()

    def _on_terminal_done(self, ok: bool):
        if ok:
            self._terminal_status.setText("✅  Done")
        else:
            self._terminal_status.setText("❌  Command finished with errors")
        if "pacman" in self._backends:
            self._backends["pacman"].refresh()

    # ── TOOLS actions ─────────────────────────────────────────────────────────

    def _run_fix_keyrings(self):
        script = (
            "pacman-key --init && "
            "pacman-key --populate archlinux && "
            "pacman -Sy --noconfirm archlinux-keyring"
        )
        self._run_terminal_cmd(
            "Fix Keyrings",
            ["pkexec", "bash", "-c", script]
        )

    def _toggle_source(self, source: str, enabled: bool):
        if enabled:
            self._active_sources.add(source)
        else:
            self._active_sources.discard(source)

    # ── Search ────────────────────────────────────────────────────────────────

    def _do_search(self):
        query = self._search_edit.text().strip()
        if not query:
            return
        if self._search_worker and self._search_worker.isRunning():
            self._search_worker.quit()

        self._results_header.setText(f'Results for "{query}"')
        self._status_label.setText("Searching…")
        self._current_results = []
        self._show_results([])
        self._stack.setCurrentIndex(1)

        self._search_worker = SearchWorker(query, self._backends, self._active_sources)
        self._search_worker.result.connect(self._on_search_results)
        self._search_worker.error.connect(lambda e: self._status_label.setText(f"Error: {e}"))
        self._search_worker.start()

    def _on_search_results(self, packages):
        self._current_results = packages
        self._show_results(packages)

    # ── Installed / Updates ───────────────────────────────────────────────────

    def _show_installed(self):
        self._results_header.setText("Installed Packages")
        self._status_label.setText("Loading…")
        installed = []
        if "pacman" in self._backends:
            localdb = self._backends["pacman"]._localdb
            for pkg in localdb.pkgcache:
                installed.append(Package(
                    name=pkg.name, version=pkg.version,
                    description=pkg.desc or "", source="pacman",
                    installed=True, icon_name=pkg.name,
                ))
        if "flatpak" in self._backends:
            try:
                for ref in self._backends["flatpak"]._inst.list_installed_refs():
                    installed.append(Package(
                        name=ref.get_appdata_name() or ref.get_name(),
                        version=ref.get_appdata_version() or "",
                        description="",
                        source="flatpak",
                        installed=True,
                        icon_name=ref.get_name().split(".")[-1].lower(),
                        flatpak_ref=ref.get_name(),
                    ))
            except Exception:
                pass
        self._current_results = installed
        self._show_results(installed)


        row = QHBoxLayout(w)
        row.setContentsMargins(0, 12, 0, 12)
        row.setSpacing(16)

        icon_lbl = QLabel()
        icon_lbl.setFixedSize(48, 48)
        themed = QIcon.fromTheme(icon_name)
        if not themed.isNull():
            icon_lbl.setPixmap(themed.pixmap(48, 48))
        else:
            icon_lbl.setPixmap(_fallback_icon(source, 48))
        row.addWidget(icon_lbl)

        txt = QVBoxLayout()
        txt.setSpacing(3)
        name_lbl = QLabel(name)
        name_lbl.setStyleSheet(f"font-size: 15px; font-weight: 700; color: {TEXT};")
        txt.addWidget(name_lbl)
        desc_lbl = QLabel(desc)
        desc_lbl.setStyleSheet(f"font-size: 12px; color: {SUBTEXT};")
        txt.addWidget(desc_lbl)
        row.addLayout(txt)
        row.addStretch()

        inst_badge = QLabel("Installed")
        inst_badge.setStyleSheet(
            f"font-size: 10px; font-weight: 600; color: {GREEN};"
            f"background: {GREEN}22; border-radius: 8px; padding: 2px 8px;"
        )
        inst_badge.setVisible(False)
        row.addWidget(inst_badge)

        install_btn = QPushButton("Install")
        install_btn.setFixedWidth(100)
        remove_btn = QPushButton("Remove")
        remove_btn.setObjectName("danger")
        remove_btn.setFixedWidth(100)
        remove_btn.setVisible(False)

        install_btn.clicked.connect(lambda _, p=pkg: self._system_install(p))
        remove_btn.clicked.connect(lambda _, p=pkg: self._system_remove(p))
        row.addWidget(install_btn)
        row.addWidget(remove_btn)

        return {
            "widget": w,
            "pkg": pkg,
            "source": source,
            "icon_lbl": icon_lbl,
            "inst_badge": inst_badge,
            "install_btn": install_btn,
            "remove_btn": remove_btn,
        }

    def _refresh_system_rows(self, rows: dict):
        if "pacman" not in self._backends:
            return
        localdb = self._backends["pacman"]._localdb
        for pkg, row in rows.items():
            installed = localdb.get_pkg(pkg) is not None
            row["inst_badge"].setVisible(installed)
            row["install_btn"].setVisible(not installed)
            row["remove_btn"].setVisible(installed)

    def _system_install(self, pkg: str):
        self._run_terminal_cmd(
            f"Installing {pkg}",
            ["pkexec", "pacman", "-S", "--noconfirm", "--needed", pkg]
        )

    def _system_remove(self, pkg: str):
        reply = QMessageBox.question(
            self, "Remove", f"Remove {pkg}?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No
        )
        if reply == QMessageBox.StandardButton.Yes:
            self._run_terminal_cmd(
                f"Removing {pkg}",
                ["pkexec", "pacman", "-R", "--noconfirm", pkg]
            )


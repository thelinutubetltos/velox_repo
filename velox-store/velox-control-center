        self._version_label.setText(f"Version: {pkg.version}")

        badge_colors = {"pacman": BADGE_PACMAN, "aur": BADGE_AUR, "flatpak": BADGE_FLATPAK}
        color = badge_colors.get(pkg.source, GREEN)
        self._source_label.setText(
            f'<span style="background:{color};color:#fff;padding:2px 8px;'
            f'border-radius:4px;">{pkg.source.upper()}</span>'
        )

        self._desc_label.setText(pkg.description or "No description available.")

        extras = []
        if pkg.size:
            extras.append(f"Installed size: {pkg.size}")
        if pkg.url:
            extras.append(f"URL: {pkg.url}")
        if pkg.votes:
            extras.append(f"AUR votes: {pkg.votes}")
        self._extra_label.setText("   •   ".join(extras))

        if pkg.installed:
            self._install_btn.setText("Reinstall")
            self._install_btn.setEnabled(True)
            self._remove_btn.setVisible(True)
        else:
            self._install_btn.setText("Install")
            self._install_btn.setEnabled(True)
            self._remove_btn.setVisible(False)

        if pkg.source == "aur":
            self._remove_btn.setVisible(pkg.installed)


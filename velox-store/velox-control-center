class PacmanBackend:
    def __init__(self):
        self._handle = pyalpm.Handle("/", "/var/lib/pacman")
        self._localdb = self._handle.get_localdb()
        self._syncdbs = []
        for db_name in ["core", "extra", "multilib", "velox_repo", "nemesis_repo", "chaotic-aur"]:
            try:
                db = self._handle.register_syncdb(db_name, pyalpm.SIG_DATABASE_OPTIONAL)
                self._syncdbs.append(db)
            except Exception:
                pass

    def search(self, query: str) -> list[Package]:
        results = []
        seen = set()
        q = query.lower()
        for db in self._syncdbs:
            try:
                for pkg in db.search(q):
                    if pkg.name in seen:
                        continue
                    seen.add(pkg.name)
                    installed = self._localdb.get_pkg(pkg.name) is not None
                    results.append(Package(
                        name=pkg.name,
                        version=pkg.version,
                        description=pkg.desc or "",
                        source="pacman",
                        installed=installed,
                        icon_name=pkg.name,
                        url=pkg.url or "",
                        size=_fmt_size(pkg.isize),
                    ))
            except Exception:
                continue
        return results

    def install(self, name: str) -> tuple[bool, str]:
        result = subprocess.run(
            ["pkexec", "pacman", "-S", "--noconfirm", "--needed", name],
            capture_output=True, text=True
        )
        return result.returncode == 0, result.stdout + result.stderr

    def remove(self, name: str) -> tuple[bool, str]:
        result = subprocess.run(
            ["pkexec", "pacman", "-R", "--noconfirm", name],
            capture_output=True, text=True
        )
        return result.returncode == 0, result.stdout + result.stderr

    def is_installed(self, name: str) -> bool:
        return self._localdb.get_pkg(name) is not None

    def refresh(self):
        self._localdb = self._handle.get_localdb()


class AURBackend:
    AUR_API = "https://aur.archlinux.org/rpc/v5/search/{}"
    AUR_GIT = "https://aur.archlinux.org/{}.git"

    def search(self, query: str) -> list[Package]:
        try:
            url = self.AUR_API.format(urllib.parse.quote(query))
            req = urllib.request.Request(url, headers={"User-Agent": "velox-store/1.0"})
            with urllib.request.urlopen(req, timeout=8) as r:
                data = json.loads(r.read())
            results = []
            local_handle = pyalpm.Handle("/", "/var/lib/pacman")
            localdb = local_handle.get_localdb()
            for item in (data.get("results") or [])[:50]:
                name = item.get("Name", "")
                installed = localdb.get_pkg(name) is not None
                results.append(Package(
                    name=name,
                    version=item.get("Version", ""),
                    description=item.get("Description") or "",
                    source="aur",
                    installed=installed,
                    icon_name=name,
                    url=f"https://aur.archlinux.org/packages/{name}",
                    votes=item.get("NumVotes", 0),
                ))
            results.sort(key=lambda p: p.votes, reverse=True)
            return results
        except Exception:
            return []

    TIMEOUT = -1  # sentinel: network/clone timeout, not a security finding

    def pkgcheck(self, name: str) -> tuple[int, str]:
        """Download PKGBUILD and run velox-pkgcheck. Returns (exit_code, output)."""
        tmpdir = tempfile.mkdtemp(prefix="velox-aur-")
        try:
            git_url = self.AUR_GIT.format(name)
            try:
                clone = subprocess.run(
                    ["git", "clone", "--depth=1", git_url, tmpdir],
                    capture_output=True, text=True, timeout=60
                )
            except subprocess.TimeoutExpired:
                return self.TIMEOUT, "Could not reach AUR git server (clone timed out)."
            if clone.returncode != 0:
                return 3, f"Failed to clone AUR repo:\n{clone.stderr}"
            pkgbuild = os.path.join(tmpdir, "PKGBUILD")
            if not os.path.exists(pkgbuild):
                return 3, "PKGBUILD not found in AUR repo."
            try:
                check = subprocess.run(
                    ["velox-pkgcheck", pkgbuild],
                    capture_output=True, text=True, timeout=60
                )
            except subprocess.TimeoutExpired:
                return self.TIMEOUT, "velox-pkgcheck scan timed out."
            return check.returncode, check.stdout + check.stderr
        except Exception as e:
            return 3, str(e)
        finally:
            shutil.rmtree(tmpdir, ignore_errors=True)

    def install(self, name: str) -> tuple[bool, str]:
        result = subprocess.run(
            ["paru", "-S", "--noconfirm", "--needed", "--skipreview", name],
            capture_output=True, text=True
        )
        return result.returncode == 0, result.stdout + result.stderr


class FlatpakBackend:
    def __init__(self):
        self._inst = Flatpak.Installation.new_system(None)

    def search(self, query: str) -> list[Package]:
        try:
            result = subprocess.run(
                ["flatpak", "search", "--columns=application,name,version,description,remotes", query],
                capture_output=True, text=True, timeout=15
            )
            packages = []
            installed_refs = {r.get_name() for r in self._inst.list_installed_refs()}
            for line in result.stdout.strip().splitlines():
                parts = line.split("\t")
                if len(parts) < 4:
                    continue
                app_id, name, version, description = parts[0], parts[1], parts[2], parts[3]
                packages.append(Package(
                    name=name,
                    version=version,
                    description=description,
                    source="flatpak",
                    installed=app_id in installed_refs,
                    icon_name=app_id.split(".")[-1].lower(),
                    flatpak_ref=app_id,
                    url=f"https://flathub.org/apps/{app_id}",
                ))
            return packages
        except Exception:
            return []

    def install(self, ref: str) -> tuple[bool, str]:
        result = subprocess.run(
            ["flatpak", "install", "--system", "--noninteractive", "-y", "flathub", ref],
            capture_output=True, text=True
        )
        return result.returncode == 0, result.stdout + result.stderr

    def remove(self, ref: str) -> tuple[bool, str]:
        result = subprocess.run(
            ["flatpak", "uninstall", "--noninteractive", "-y", ref],
            capture_output=True, text=True
        )
        return result.returncode == 0, result.stdout + result.stderr


def _fmt_size(b: int) -> str:
    if not b:
        return ""
    for unit in ("B", "KB", "MB", "GB"):
        if b < 1024:
            return f"{b:.1f} {unit}"
        b /= 1024
    return f"{b:.1f} TB"

# ── Worker threads ────────────────────────────────────────────────────────────

class SearchWorker(QThread):
    result = pyqtSignal(list)
    error  = pyqtSignal(str)

    def __init__(self, query, backends, sources):
        super().__init__()
        self.query = query
        self.backends = backends
        self.sources = sources

    def run(self):
        all_results = []
        for source, backend in self.backends.items():
            if source not in self.sources:
                continue
            try:
                all_results.extend(backend.search(self.query))
            except Exception as e:
                self.error.emit(f"{source}: {e}")
        self.result.emit(all_results)


class PkgCheckWorker(QThread):
    done = pyqtSignal(int, str)

    def __init__(self, aur_backend, name):
        super().__init__()
        self.aur = aur_backend
        self.name = name

    def run(self):
        code, output = self.aur.pkgcheck(self.name)
        self.done.emit(code, output)


class InstallWorker(QThread):
    done = pyqtSignal(bool, str)

    def __init__(self, pkg, backends):
        super().__init__()
        self.pkg = pkg
        self.backends = backends

    def run(self):
        p = self.pkg
        if p.source == "pacman":
            ok, out = self.backends["pacman"].install(p.name)
        elif p.source == "aur":
            ok, out = self.backends["aur"].install(p.name)
        elif p.source == "flatpak":
            ok, out = self.backends["flatpak"].install(p.flatpak_ref or p.name)
        else:
            ok, out = False, "Unknown source"
        self.done.emit(ok, out)


class RemoveWorker(QThread):
    done = pyqtSignal(bool, str)

    def __init__(self, pkg, backends):
        super().__init__()
        self.pkg = pkg
        self.backends = backends

    def run(self):
        p = self.pkg
        if p.source == "pacman":
            ok, out = self.backends["pacman"].remove(p.name)
        elif p.source == "flatpak":
            ok, out = self.backends["flatpak"].remove(p.flatpak_ref or p.name)
        else:
            ok, out = False, "AUR packages must be removed via pacman."
        self.done.emit(ok, out)

class TerminalWorker(QThread):
    line_ready  = pyqtSignal(str)
    finished_ok = pyqtSignal(bool)

    def __init__(self, cmd: list):
        super().__init__()
        self.cmd = cmd

    def run(self):
        try:
            proc = subprocess.Popen(
                self.cmd, stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT, text=True, bufsize=1
            )
            for line in proc.stdout:
                self.line_ready.emit(line.rstrip())
            proc.wait()
            self.finished_ok.emit(proc.returncode == 0)
        except Exception as e:
            self.line_ready.emit(f"Error: {e}")
            self.finished_ok.emit(False)

class ArchNewsWorker(QThread):
    done = pyqtSignal(list)   # list of (title, link, date_str, is_recent)

    _URL = "https://archlinux.org/feeds/news/"
    _RECENT_DAYS = 14

    def run(self):
        try:
            req = urllib.request.Request(
                self._URL, headers={"User-Agent": "velox-control-center/1.0"}
            )
            with urllib.request.urlopen(req, timeout=10) as r:
                data = r.read()
            root = ET.fromstring(data)
            cutoff = datetime.now(timezone.utc) - timedelta(days=self._RECENT_DAYS)
            items = []
            for item in root.findall(".//item")[:5]:
                title = (item.findtext("title") or "").strip()
                link  = (item.findtext("link")  or "").strip()
                pub   = (item.findtext("pubDate") or "").strip()
                try:
                    dt = email.utils.parsedate_to_datetime(pub)
                    if dt.tzinfo is None:
                        dt = dt.replace(tzinfo=timezone.utc)
                    is_recent = dt >= cutoff
                    date_str = dt.strftime("%Y-%m-%d")
                except Exception:
                    is_recent = False
                    date_str = pub[:16] if pub else ""
                items.append((title, link, date_str, is_recent))
            self.done.emit(items)
        except Exception:
            self.done.emit([])


class UpdateCheckWorker(QThread):
    done = pyqtSignal(list, list)   # (pacman_updates, flatpak_updates)

    def __init__(self, flatpak_backend):
        super().__init__()
        self._flatpak = flatpak_backend

    def run(self):
        pacman_updates = []
        try:
            cmd = ["checkupdates"] if shutil.which("checkupdates") else ["pacman", "-Qu"]
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
            for line in r.stdout.strip().splitlines():
                parts = line.split()
                if len(parts) >= 4:
                    pacman_updates.append((parts[0], parts[1], parts[3]))
        except Exception:
            pass

        flatpak_updates = []
        if self._flatpak:
            try:
                subprocess.run(["flatpak", "update", "--appstream", "-y"],
                               capture_output=True, text=True, timeout=30)
                for ref in self._flatpak._inst.list_installed_refs():
                    try:
                        rref = self._flatpak._inst.fetch_remote_ref_sync(
                            ref.get_remote_name(), Flatpak.RefKind.APP,
                            ref.get_name(), ref.get_arch(), ref.get_branch(), None
                        )
                        if rref and rref.get_commit() != ref.get_commit():
                            flatpak_updates.append((
                                ref.get_appdata_name() or ref.get_name(),
                                ref.get_appdata_version() or "", ""
                            ))
                    except Exception:
                        pass
            except Exception:
                pass

        self.done.emit(pacman_updates, flatpak_updates)


    def _show_updates(self):
        # Show page immediately with loading state
        self._stack.setCurrentIndex(7)
        self._upd_status.setText("Checking for updates…")
        self._upd_all_btn.setEnabled(False)

        while self._upd_layout.count() > 1:
            item = self._upd_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()

        loading = QLabel("Checking for updates…")
        loading.setStyleSheet(f"font-size: 14px; color: {SUBTEXT}; padding: 40px;")
        loading.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self._upd_layout.insertWidget(0, loading)

        self._update_worker = UpdateCheckWorker(self._backends.get("flatpak"))
        self._update_worker.done.connect(self._on_updates_done)
        self._update_worker.start()

        # Fetch Arch news in parallel
        self._news_status_lbl.setText("Loading…")
        self._news_status_lbl.setStyleSheet(f"font-size: 11px; color: {SUBTEXT};")
        while self._news_items_layout.count():
            it = self._news_items_layout.takeAt(0)
            if it.widget():
                it.widget().deleteLater()
        self._arch_news = []
        self._news_worker = ArchNewsWorker()
        self._news_worker.done.connect(self._on_news_done)
        self._news_worker.start()

    def _on_updates_done(self, pacman_updates: list, flatpak_updates: list):
        while self._upd_layout.count() > 1:
            item = self._upd_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()

        total = len(pacman_updates) + len(flatpak_updates)

        if total == 0:
            self._upd_status.setText("All up to date")
            self._upd_all_btn.setEnabled(False)
            empty = QWidget()
            vbox = QVBoxLayout(empty)
            vbox.setAlignment(Qt.AlignmentFlag.AlignCenter)
            vbox.setContentsMargins(0, 80, 0, 0)
            vbox.setSpacing(14)
            ok = QLabel("✅")
            ok.setAlignment(Qt.AlignmentFlag.AlignCenter)
            ok.setStyleSheet("font-size: 56px;")
            vbox.addWidget(ok)
            t = QLabel("Everything is up to date!")
            t.setAlignment(Qt.AlignmentFlag.AlignCenter)
            t.setStyleSheet(f"font-size: 22px; font-weight: bold; color: {TEXT};")
            vbox.addWidget(t)
            s = QLabel("All packages are at their latest versions.")
            s.setAlignment(Qt.AlignmentFlag.AlignCenter)
            s.setStyleSheet(f"font-size: 14px; color: {SUBTEXT};")
            vbox.addWidget(s)
            self._upd_layout.insertWidget(0, empty)
            return

        self._upd_status.setText(f"{total} update{'s' if total != 1 else ''} available")
        self._upd_all_btn.setEnabled(True)
        idx = 0

        def insert(w):
            nonlocal idx
            self._upd_layout.insertWidget(idx, w)
            idx += 1

        if pacman_updates:
            insert(self._make_source_header("pacman"))
            for name, old_ver, new_ver in pacman_updates:
                insert(self._make_update_row(name, old_ver, new_ver, "pacman"))
                sep = QFrame(); sep.setFrameShape(QFrame.Shape.HLine)
                sep.setStyleSheet("color: #282828;"); insert(sep)

        if flatpak_updates:
            insert(self._make_source_header("flatpak"))
            for name, old_ver, new_ver in flatpak_updates:
                insert(self._make_update_row(name, old_ver, new_ver, "flatpak"))
                sep = QFrame(); sep.setFrameShape(QFrame.Shape.HLine)
                sep.setStyleSheet("color: #282828;"); insert(sep)

    def _on_news_done(self, items: list):
        self._arch_news = items
        while self._news_items_layout.count():
            it = self._news_items_layout.takeAt(0)
            if it.widget():
                it.widget().deleteLater()

        if not items:
            self._news_status_lbl.setText("Could not fetch news")
            self._news_status_lbl.setStyleSheet(f"font-size: 11px; color: {SUBTEXT};")
            return

        recent_count = sum(1 for _, _, _, is_r in items if is_r)
        if recent_count:
            self._news_status_lbl.setText(
                f"⚠  {recent_count} recent item{'s' if recent_count > 1 else ''} — read before updating"
            )
            self._news_status_lbl.setStyleSheet(
                "font-size: 11px; color: #FF9800; font-weight: 600;"
            )
            self._news_frame.setStyleSheet(
                "QFrame { background: #1e1500; border-radius: 10px; border: 1px solid #FF980066; }"
            )
        else:
            self._news_status_lbl.setText("No recent alerts")
            self._news_status_lbl.setStyleSheet(f"font-size: 11px; color: {GREEN};")
            self._news_frame.setStyleSheet(
                "QFrame { background: #1a1a2a; border-radius: 10px; border: 1px solid #2a2a4a; }"
            )

        for title, link, date_str, is_recent in items:
            row = QWidget()
            row.setStyleSheet("background: transparent;")
            row_layout = QHBoxLayout(row)
            row_layout.setContentsMargins(0, 1, 0, 1)
            row_layout.setSpacing(8)

            if is_recent:
                badge = QLabel("RECENT")
                badge.setFixedWidth(48)
                badge.setAlignment(Qt.AlignmentFlag.AlignCenter)
                badge.setStyleSheet(
                    "font-size: 8px; font-weight: 700; color: #FF9800;"
                    "background: #FF980033; border-radius: 4px; padding: 1px 4px;"
                )
                row_layout.addWidget(badge)

            title_lbl = QLabel(title)
            title_lbl.setStyleSheet(
                f"background: transparent; font-size: 11px;"
                f"color: {'#FF9800' if is_recent else TEXT};"
                f"font-weight: {'600' if is_recent else '400'};"
            )
            row_layout.addWidget(title_lbl)
            row_layout.addStretch()

            date_lbl = QLabel(date_str)
            date_lbl.setStyleSheet(f"background: transparent; font-size: 10px; font-weight: 600; color: {TEXT};")
            date_lbl.setFixedWidth(76)
            row_layout.addWidget(date_lbl)

            if link:
                read_btn = QPushButton("Read →")
                read_btn.setFixedWidth(72)
                read_btn.setFixedHeight(22)
                read_btn.setStyleSheet(
                    f"QPushButton {{ background: transparent; color: {GREEN}; border: 1px solid {GREEN}88;"
                    f"border-radius: 10px; font-size: 10px; font-weight: 600; padding: 0 6px; }}"
                    f"QPushButton:hover {{ background: {GREEN}22; }}"
                )
                read_btn.clicked.connect(lambda _, url=link: subprocess.Popen(["xdg-open", url]))
                row_layout.addWidget(read_btn)

            self._news_items_layout.addWidget(row)

    def _make_update_row(self, name: str, old_ver: str, new_ver: str, source: str) -> QWidget:
        w = QWidget()
        w.setMinimumHeight(52)
        row = QHBoxLayout(w)
        row.setContentsMargins(4, 8, 4, 8)
        row.setSpacing(14)

        badge = QLabel(source.upper())
        badge.setStyleSheet(BADGE_STYLES.get(source, ""))
        badge.setFixedWidth(68)
        row.addWidget(badge)

        name_lbl = QLabel(name)
        name_lbl.setStyleSheet(f"font-size: 13px; font-weight: 600; color: {TEXT};")
        row.addWidget(name_lbl)
        row.addStretch()

        if old_ver or new_ver:
            ver_lbl = QLabel(f"{old_ver}  →  {new_ver}" if new_ver else old_ver)
            ver_lbl.setStyleSheet(f"font-size: 12px; color: {SUBTEXT};")
            row.addWidget(ver_lbl)
        return w

    def _run_update_all(self):
        recent = [(t, l, d) for t, l, d, is_r in self._arch_news if is_r]
        if recent:
            msg = QMessageBox(self)
            msg.setWindowTitle("Review Arch News Before Updating")
            msg.setIcon(QMessageBox.Icon.Warning)
            items_text = "\n".join(f"  •  {title}  ({date})" for title, _, date in recent)
            msg.setText(
                f"There {'is' if len(recent) == 1 else 'are'} {len(recent)} recent Arch Linux "
                f"news item{'s' if len(recent) > 1 else ''} that may require manual steps "
                f"before updating:\n\n{items_text}\n\n"
                "Some updates need manual action first — skipping them can break your system.\n"
                "Please read the news items above before continuing."
            )
            update_btn = msg.addButton("Update Anyway", QMessageBox.ButtonRole.AcceptRole)
            msg.addButton("Cancel", QMessageBox.ButtonRole.RejectRole)
            msg.exec()
            if msg.clickedButton() != update_btn:
                return

        cmd = "pkexec pacman -Syu --noconfirm"
        if shutil.which("flatpak"):
            cmd += " && flatpak update -y"
        self._run_terminal_cmd("Update All", ["bash", "-c", cmd])

    # ── Install / Remove ──────────────────────────────────────────────────────

    def _on_install(self, pkg: Package):
        if pkg.source == "aur":
            self._run_pkgcheck_then_install(pkg)
        else:
            self._run_install(pkg)

    def _run_pkgcheck_then_install(self, pkg: Package):
        self._detail_view.set_buttons_enabled(False)
        self._progress = QProgressDialog(
            f"Running velox-pkgcheck on {pkg.name}…", None, 0, 0, self
        )
        self._progress.setWindowTitle("Security Check")
        self._progress.setModal(True)
        self._progress.show()

        self._pkgcheck_worker = PkgCheckWorker(self._backends["aur"], pkg.name)
        self._pkgcheck_worker.done.connect(lambda code, out: self._on_pkgcheck_done(code, out, pkg))
        self._pkgcheck_worker.start()

    def _on_pkgcheck_done(self, code: int, output: str, pkg: Package):
        self._progress.close()
        self._detail_view.set_buttons_enabled(True)

        if code == AURBackend.TIMEOUT:
            # Network/timeout — not a security finding, let user decide
            dlg = QMessageBox(self)
            dlg.setWindowTitle("Security Check Unavailable")
            dlg.setIcon(QMessageBox.Icon.Warning)
            dlg.setText(
                f"Could not complete the security scan for <b>{pkg.name}</b> "
                "(network timeout).<br><br>"
                "This does <b>not</b> mean the package is unsafe — the scan simply "
                "couldn't reach the server in time."
            )
            dlg.setDetailedText(output)
            install_btn = dlg.addButton("Install Anyway", QMessageBox.ButtonRole.AcceptRole)
            dlg.addButton("Retry", QMessageBox.ButtonRole.ResetRole)
            dlg.addButton("Cancel", QMessageBox.ButtonRole.RejectRole)
            dlg.exec()
            clicked = dlg.clickedButton()
            if clicked == install_btn:
                self._run_install(pkg)
            elif clicked.text() == "Retry":
                self._run_pkgcheck_then_install(pkg)
        elif code == 0:
            self._run_install(pkg)
        elif code in (1, 2):
            dlg = _PkgCheckDialog(pkg.name, code, output, allow_proceed=True, parent=self)
            if dlg.exec() == QDialog.DialogCode.Accepted:
                self._run_install(pkg)
        elif code >= 3:
            dlg = _PkgCheckDialog(pkg.name, code, output, allow_proceed=(code == 3), parent=self)
            if dlg.exec() == QDialog.DialogCode.Accepted:
                self._run_install(pkg)

    def _run_install(self, pkg: Package):
        self._detail_view.set_buttons_enabled(False)
        self._progress = QProgressDialog(
            f"Installing {pkg.name}…", None, 0, 0, self
        )
        self._progress.setWindowTitle("Installing")
        self._progress.setModal(True)
        self._progress.show()

        self._install_worker = InstallWorker(pkg, self._backends)
        self._install_worker.done.connect(lambda ok, out: self._on_install_done(ok, out, pkg))
        self._install_worker.start()

    def _on_install_done(self, ok: bool, output: str, pkg: Package):
        self._progress.close()
        if "pacman" in self._backends:
            self._backends["pacman"].refresh()
        pkg.installed = ok
        self._detail_view.show_package(pkg)
        self._detail_view.set_buttons_enabled(True)
        if ok:
            QMessageBox.information(self, "Installed", f"{pkg.name} installed successfully.")
        else:
            dlg = QMessageBox(self)
            dlg.setWindowTitle("Install Failed")
            dlg.setText(f"Failed to install {pkg.name}.")
            dlg.setDetailedText(output)
            dlg.exec()

    def _on_remove(self, pkg: Package):
        reply = QMessageBox.question(
            self, "Remove Package",
            f"Remove {pkg.name}?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No
        )
        if reply != QMessageBox.StandardButton.Yes:
            return

        self._detail_view.set_buttons_enabled(False)
        self._progress = QProgressDialog(f"Removing {pkg.name}…", None, 0, 0, self)
        self._progress.setWindowTitle("Removing")
        self._progress.setModal(True)
        self._progress.show()

        self._remove_worker = RemoveWorker(pkg, self._backends)
        self._remove_worker.done.connect(lambda ok, out: self._on_remove_done(ok, out, pkg))
        self._remove_worker.start()

    def _on_remove_done(self, ok: bool, output: str, pkg: Package):
        self._progress.close()
        if "pacman" in self._backends:
            self._backends["pacman"].refresh()
        pkg.installed = not ok
        self._detail_view.show_package(pkg)
        self._detail_view.set_buttons_enabled(True)
        if ok:
            QMessageBox.information(self, "Removed", f"{pkg.name} removed.")
        else:
            dlg = QMessageBox(self)
            dlg.setWindowTitle("Remove Failed")
            dlg.setText(f"Failed to remove {pkg.name}.")
            dlg.setDetailedText(output)
            dlg.exec()


# ── velox-pkgcheck result dialog ──────────────────────────────────────────────

class _PkgCheckDialog(QDialog):
    SEVERITY = {0: ("Clean", GREEN), 1: ("Info", "#2196F3"),
                2: ("Warning", "#FF9800"), 3: ("High Risk", "#FF5722"),
                4: ("CRITICAL — BLOCKED", "#c0392b")}

    def __init__(self, pkg_name, code, output, allow_proceed, parent=None):
        super().__init__(parent)
        sev_label, sev_color = self.SEVERITY.get(code, ("Unknown", SUBTEXT))
        self.setWindowTitle("Security Scan Result")
        self.setMinimumSize(580, 420)

        layout = QVBoxLayout(self)
        layout.setSpacing(12)

        header = QLabel(f"velox-pkgcheck: {pkg_name}")
        header.setStyleSheet(f"font-size: 16px; font-weight: bold; color: {TEXT};")
        layout.addWidget(header)

        sev = QLabel(f"Severity: {sev_label}")
        sev.setStyleSheet(f"font-size: 14px; font-weight: bold; color: {sev_color};")
        layout.addWidget(sev)

        out_box = QTextEdit()
        out_box.setReadOnly(True)
        out_box.setPlainText(output or "(no output)")
        out_box.setFixedHeight(220)
        layout.addWidget(out_box)

        if code == 4:
            warn = QLabel("⛔ Installation blocked due to critical security findings.")
            warn.setStyleSheet(f"color: #c0392b; font-weight: bold;")
            warn.setWordWrap(True)
            layout.addWidget(warn)
            buttons = QDialogButtonBox(QDialogButtonBox.StandardButton.Close)
            buttons.rejected.connect(self.reject)
        elif allow_proceed:
            warn_text = {
                1: "This package has informational findings. You may proceed.",
                2: "This package has medium-risk findings. Proceed with caution.",
                3: "⚠ HIGH RISK findings detected. Only proceed if you trust this package.",
            }.get(code, "")
            warn = QLabel(warn_text)
            warn.setStyleSheet(f"color: {sev_color}; font-weight: bold;")
            warn.setWordWrap(True)
            layout.addWidget(warn)
            buttons = QDialogButtonBox(
                QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel
            )
            buttons.button(QDialogButtonBox.StandardButton.Ok).setText("Install Anyway")
            buttons.accepted.connect(self.accept)
            buttons.rejected.connect(self.reject)
        else:
            buttons = QDialogButtonBox(QDialogButtonBox.StandardButton.Close)
            buttons.rejected.connect(self.reject)

        layout.addWidget(buttons)



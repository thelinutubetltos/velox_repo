@dataclass
class Package:
    name: str
    version: str
    description: str
    source: str          # 'pacman' | 'aur' | 'flatpak'
    installed: bool = False
    icon_name: str = ""
    url: str = ""
    size: str = ""
    votes: int = 0       # AUR only
    flatpak_ref: str = ""  # Flatpak only

# ── Icon loader ───────────────────────────────────────────────────────────────

_ICON_CACHE: dict[str, QPixmap] = {}

def load_icon(name: str, source: str, size: int = 48) -> QPixmap:
    cache_key = f"{name}:{source}:{size}"
    if cache_key in _ICON_CACHE:
        return _ICON_CACHE[cache_key]
    px = _load_icon_uncached(name, source, size)
    _ICON_CACHE[cache_key] = px
    return px

def _load_icon_uncached(name: str, source: str, size: int) -> QPixmap:
    if name:
        icon = QIcon.fromTheme(name)
        if not icon.isNull():
            return icon.pixmap(size, size)
        icon = QIcon.fromTheme(name.lower())
        if not icon.isNull():
            return icon.pixmap(size, size)
        for path in [f"/usr/share/pixmaps/{name}.png",
                     f"/usr/share/pixmaps/{name}.svg",
                     f"/usr/share/icons/hicolor/48x48/apps/{name}.png",
                     f"/usr/share/icons/hicolor/scalable/apps/{name}.svg"]:
            if os.path.exists(path):
                px = QPixmap(path)
                if not px.isNull():
                    return px.scaled(size, size, Qt.AspectRatioMode.KeepAspectRatio,
                                     Qt.TransformationMode.SmoothTransformation)
    return _fallback_icon(source, size)


class IconLoader(QThread):
    """Loads icons for a batch of cards in the background."""
    icon_ready = pyqtSignal(str, str, int, QPixmap)  # name, source, size, pixmap

    def __init__(self, tasks: list[tuple[str, str, int]]):
        super().__init__()
        self.tasks = tasks

    def run(self):
        for name, source, size in self.tasks:
            cache_key = f"{name}:{source}:{size}"
            if cache_key not in _ICON_CACHE:
                px = _load_icon_uncached(name, source, size)
                _ICON_CACHE[cache_key] = px
            self.icon_ready.emit(name, source, size, _ICON_CACHE[cache_key])

def _fallback_icon(source: str, size: int) -> QPixmap:
    colors = {"pacman": BADGE_PACMAN, "aur": BADGE_AUR, "flatpak": BADGE_FLATPAK}
    color = colors.get(source, GREEN)
    px = QPixmap(size, size)
    px.fill(Qt.GlobalColor.transparent)
    p = QPainter(px)
    p.setRenderHint(QPainter.RenderHint.Antialiasing)
    p.setBrush(QColor(color))
    p.setPen(Qt.PenStyle.NoPen)
    p.drawRoundedRect(0, 0, size, size, size * 0.2, size * 0.2)
    p.setPen(QColor("#fff"))
    f = QFont("Noto Sans", size // 3, QFont.Weight.Bold)
    p.setFont(f)
    p.drawText(0, 0, size, size, Qt.AlignmentFlag.AlignCenter,
               source[0].upper())
    p.end()
    return px


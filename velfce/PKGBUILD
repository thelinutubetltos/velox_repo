pkgname=velfce
pkgver=1.0
pkgrel=1
pkgdesc="Velox XFCE — XFCE desktop environment with Velox theming"
arch=('any')
url="https://github.com/thelinutubetltos/velox-iso"
license=('custom')
depends=(
    # Core XFCE desktop
    'exo'
    'garcon'
    'xfce4-session'
    'xfce4-panel'
    'xfce4-settings'
    'xfconf'
    'xfdesktop'
    'xfwm4'
    'xfce4-appfinder'
    'xfce4-power-manager'
    # File manager
    'thunar'
    'thunar-volman'
    'thunar-archive-plugin'
    'tumbler'
    # Apps
    'xfce4-terminal'
    'mousepad'
    'ristretto'
    'parole'
    # Panel extras
    'xfce4-notifyd'
    'xfce4-screenshooter'
    'xfce4-taskmanager'
    'xfce4-pulseaudio-plugin'
    'xfce4-whiskermenu-plugin'
    'xfce4-clipman-plugin'
    'xfce4-screensaver'
    # Theming
    'arc-gtk-theme'
    'papirus-icon-theme'
    'noto-fonts'
    'breeze'
)
source=()

package() {
    local src="$startdir"

    # GTK 3 theme defaults
    install -Dm644 "$src/skel/.config/gtk-3.0/settings.ini" \
        "$pkgdir/etc/skel/.config/gtk-3.0/settings.ini"

    # GTK 4 theme defaults
    install -Dm644 "$src/skel/.config/gtk-4.0/settings.ini" \
        "$pkgdir/etc/skel/.config/gtk-4.0/settings.ini"

    # XFCE appearance settings (GTK theme, icons, fonts)
    install -Dm644 "$src/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml" \
        "$pkgdir/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml"

    # XFCE window manager theme
    install -Dm644 "$src/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfwm4.xml" \
        "$pkgdir/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfwm4.xml"

    # XFCE desktop wallpaper
    install -Dm644 "$src/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-desktop.xml" \
        "$pkgdir/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-desktop.xml"

    # Thunar preferences
    install -Dm644 "$src/skel/.config/xfce4/xfconf/xfce-perchannel-xml/thunar.xml" \
        "$pkgdir/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml/thunar.xml"
}

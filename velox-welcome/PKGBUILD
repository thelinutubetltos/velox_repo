pkgname=velox-welcome
pkgver=2.0
pkgrel=1
pkgdesc="Velox Linux Welcome App — first steps, package installer, snapshots"
arch=('any')
url="https://github.com/thelinutubetltos/velox-iso"
license=('GPL3')
depends=('python-pyqt6' 'paru')
optdepends=('flatpak: Flatpak package search and install support'
            'yay: Alternative AUR helper'
            'snapper: Btrfs snapshot management'
            'grub-btrfs: Boot into snapshots from GRUB')
source=("velox-welcome::https://raw.githubusercontent.com/thelinutubetltos/velox-iso/main/archiso/airootfs/usr/bin/velox-welcome"
        "velox-welcome.desktop"
        "velox-logo.png")
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
    mkdir -p "$pkgdir/usr/bin"
    mkdir -p "$pkgdir/usr/share/applications"
    mkdir -p "$pkgdir/usr/share/velox-welcome"

    install -m 755 "$srcdir/velox-welcome" "$pkgdir/usr/bin/velox-welcome"
    install -m 644 "$srcdir/velox-welcome.desktop" "$pkgdir/usr/share/applications/"
    install -m 644 "$srcdir/velox-logo.png" "$pkgdir/usr/share/velox-welcome/"
}
